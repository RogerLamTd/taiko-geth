  "definitions": {
    "*big.Int": {
      "examples": [
        10000
      ],
      "type": "integer"
    },
    "*math.HexOrDecimal256": {
      "$ref": "#/definitions/*big.Int",
      "description": "Hexadecimal or decimal representation of a number."
