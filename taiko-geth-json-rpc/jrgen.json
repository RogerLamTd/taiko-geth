        "EstimatedGasUsed": {
          "examples": [
            10000
          ],
          "type": "integer"
        },
        "TxList": {
          "type": "array"
        }
      },
      "required": [
        "TxList",
        "EstimatedGasUsed",
        "BytesLength"
      ],
      "type": "object"
    },
