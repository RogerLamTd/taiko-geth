{
  "$schema": "https://rawgit.com/mzernetsch/jrgen/master/jrgen-spec.schema.json",
  "jrgen": "1.2",
  "jsonrpc": "2.0",
  "info": {
    "title": "Taiko JSON-RPC API",
    "description": [
      "Auto-generated JSON-RPC API for Taiko backend."
