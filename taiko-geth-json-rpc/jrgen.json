          ],
          "type": "string"
        },
        "l1BlockHeight": {
          "$ref": "#/definitions/*big.Int"
        },
        "l2BlockHash": {
          "examples": [
            "0x123456"
          ],
          "type": "string"
        }
      },
      "required": [
        "blockID",
        "l2BlockHash",
        "l1BlockHeight",
        "l1BlockHash"
      ],
      "type": "object"
    }
  },
